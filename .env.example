# ============================================================
# Haven Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# ── Stripe ───────────────────────────────────────────────────
# Find this in: Stripe Dashboard → Developers → API Keys
# Use pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-stripe-publishable-key>

# ── Supabase Edge Function Secrets (set via Supabase CLI) ────
# These are NOT prefixed with VITE_ — they live server-side only.
# Set them with: supabase secrets set KEY=value
#
# STRIPE_SECRET_KEY=sk_test_...          # Stripe secret key
# STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe webhook signing secret
# OPENAI_API_KEY=sk-...                  # For AI content generation
# ADVANCECM_API_KEY=...                  # AdvanceCM/Tokeet PMS API key
# GUESTY_API_KEY=...                     # Guesty PMS API key
# PMS_WEBHOOK_SECRET=...                 # Webhook verification token
